{
  "name": "calorie-tracker",
  "version": "1.0.0",
  "description": "Calorie Tracker — a native macOS desktop app for tracking daily macros and calories.",
  "author": "Joji Jacob",
  "license": "MIT",
  "main": "electron/main.js",
  "private": true,
  "scripts": {
    "dev": "concurrently -k -n vite,electron -c green,cyan \"vite\" \"wait-on tcp:127.0.0.1:5173 && electron .\"",
    "build": "vite build",
    "preview": "vite preview",
    "start": "npm run build && electron .",
    "dist": "npm run build && electron-builder --mac",
    "dist:dir": "npm run build && electron-builder --mac dir",
    "ios:add": "npm run build && cap add ios",
    "ios:sync": "npm run build && cap sync ios",
    "ios:open": "npm run build && cap sync ios && cap open ios"
  },
  "dependencies": {
    "@capacitor/core": "^6.2.1",
    "@capacitor/ios": "^6.2.1",
    "@capacitor/status-bar": "^6.0.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^2.15.4"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.2.1",
    "@vitejs/plugin-react": "^4.7.0",
    "concurrently": "^8.2.2",
    "electron": "^31.3.1",
    "electron-builder": "^24.13.3",
    "vite": "^5.4.21",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.jojijacob.calorietracker",
    "productName": "Calorie Tracker",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "mac": {
      "category": "public.app-category.healthcare-fitness",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ],
      "icon": "build/icon.icns",
      "darkModeSupport": true,
      "hardenedRuntime": true,
      "gatekeeperAssess": false
    },
    "dmg": {
      "title": "Calorie Tracker",
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    }
  }
}
